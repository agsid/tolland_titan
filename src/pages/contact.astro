---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import siteData from '../data/landing.json';
import "../styles/global.css";

const { logistics, hero } = siteData;
---

<Layout title="Contact Us | Tolland County Titans #23535">
  <div class="relative min-h-screen w-full bg-brand-bg text-neutral-900 flex flex-col items-center overflow-x-hidden pb-12 font-sans">
    
    <Navbar />

    <main class="relative z-10 w-full max-w-6xl px-4 mt-8 md:mt-16 grid lg:grid-cols-12 gap-6 items-stretch">
      
      <div class="lg:col-span-5 flex flex-col gap-6 justify-between h-full">
        
        <div class="bg-white border-2 border-black rounded-xl p-6 sm:p-8 flex flex-col justify-center flex-1 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
          <span class="text-[10px] font-mono font-bold tracking-wider text-neutral-400 uppercase">Contact Options</span>
          <h1 class="text-2xl sm:text-3xl font-black text-black tracking-tight mt-1 mb-3 uppercase">Get in Touch</h1>
          <p class="text-neutral-600 text-xs sm:text-sm leading-relaxed">
            Reach out to our team using the verified email addresses below. Inquiries are monitored by our team mentors and student leaders.
          </p>
        </div>

        <div class="bg-white border-2 border-black rounded-xl p-6 flex flex-col gap-3 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
          <span class="text-[10px] uppercase font-mono font-bold text-neutral-400 mb-0.5">Email Directory</span>
          
          <div class="space-y-3">
            <a href="mailto:mentors@tollandcountytitans.org" class="group flex justify-between items-center bg-neutral-50 border border-black hover:bg-black hover:text-white p-4 rounded-lg transition-all duration-200">
              <div>
                <p class="text-xs font-bold uppercase tracking-wide">General & Student Inquiries</p>
                <p class="text-[11px] text-neutral-500 font-mono mt-0.5 group-hover:text-neutral-300">mymacary@tcrobotics.org.</p>
              </div>
              <span class="font-mono font-bold transform group-hover:translate-x-1 transition-all">→</span>
            </a>

            <a href="mailto:sponsors@tollandcountytitans.org" class="group flex justify-between items-center bg-neutral-50 border border-black hover:bg-black hover:text-white p-4 rounded-lg transition-all duration-200">
              <div>
                <p class="text-xs font-bold uppercase tracking-wide">Sponsorships & Donations</p>
                <p class="text-[11px] text-neutral-500 font-mono mt-0.5 group-hover:text-neutral-300">sponsors@tollandcountytitans.org</p>
              </div>
              <span class="font-mono font-bold transform group-hover:translate-x-1 transition-all">→</span>
            </a>
          </div>
        </div>

        <div class="bg-white border-2 border-black rounded-xl p-6 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
          <span class="text-[10px] uppercase tracking-wider font-mono font-bold text-neutral-400 mb-1.5 block">Meeting Location</span>
          <p class="text-xs font-bold uppercase text-black">{logistics?.locationName || "Titans Engineering Lab"}</p>
          <p class="text-[11px] text-neutral-600 mt-0.5 font-mono">{logistics?.address || "Tolland County Workshop Space"}</p>
        </div>

      </div>

      <div class="lg:col-span-7 w-full bg-white border-2 border-black rounded-xl p-6 sm:p-10 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] flex flex-col justify-center">
        <h2 class="text-lg font-black text-black mb-0.5 uppercase tracking-wide font-mono">Send a Message</h2>
        <p class="text-xs text-neutral-500 font-mono mb-6">Fill out the form fields below to contact our staff directly.</p>
        
        <form class="space-y-5">
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label class="text-[10px] font-bold text-neutral-400 font-mono uppercase tracking-widest">Full Name</label>
              <input 
                type="text" 
                required 
                class="w-full bg-neutral-50 border-2 border-black rounded-lg px-4 py-3 text-xs font-mono text-black placeholder:text-neutral-400 focus:outline-none focus:bg-white transition-all"
                placeholder="Your Name"
              />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[10px] font-bold text-neutral-400 font-mono uppercase tracking-widest">Email Address</label>
              <input 
                type="email" 
                required 
                class="w-full bg-neutral-50 border-2 border-black rounded-lg px-4 py-3 text-xs font-mono text-black placeholder:text-neutral-400 focus:outline-none focus:bg-white transition-all"
                placeholder="your.email@example.com"
              />
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-[10px] font-bold text-neutral-400 font-mono uppercase tracking-widest">Inquiry Topic</label>
            <div class="relative">
              <select class="w-full bg-neutral-50 border-2 border-black rounded-lg px-4 py-3 text-xs font-mono text-black focus:outline-none focus:bg-white cursor-pointer appearance-none transition-all">
                <option>Student Registration & Intake (Grades 6-10)</option>
                <option>Adult Mentorship & Volunteering</option>
                <option>Sponsorships & Corporate Partnerships</option>
                <option>General Inquiries</option>
              </select>
              <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-black text-[10px] font-mono">
                ▼
              </div>
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-[10px] font-bold text-neutral-400 font-mono uppercase tracking-widest">Message Message</label>
            <textarea 
              rows="5" 
              required 
              class="w-full bg-neutral-50 border-2 border-black rounded-lg px-4 py-3 text-xs font-mono text-black placeholder:text-neutral-400 focus:outline-none focus:bg-white transition-all resize-none"
              placeholder="Write your message details here..."
            ></textarea>
          </div>

          <div class="pt-3 flex justify-start items-center">
            <button 
              type="submit" 
              class="w-full sm:w-auto px-6 py-3 bg-black text-white text-xs font-mono font-bold uppercase tracking-wider rounded-lg border-2 border-black shadow-[3px_3px_0px_0px_rgba(0,0,0,0.2)] hover:bg-white hover:text-black hover:shadow-[5px_5px_0px_0px_rgba(0,0,0,1)] active:translate-x-[2px] active:translate-y-[2px] active:shadow-none transition-all duration-150"
            >
              Submit Message
            </button>
          </div>
        </form>
      </div>

    </main>

    <footer class="w-full text-center mt-auto pt-16 pb-4 text-[10px] tracking-widest text-neutral-400 font-mono uppercase">
      © {new Date().getFullYear()} Tolland County Robotics Foundation • Team #{hero?.teamNumber || "23535"}
    </footer>

  </div>
</Layout>