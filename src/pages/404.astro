---
// src/pages/404.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';
---

<Layout title="Page Not Found | #23535">
  <div class="relative min-h-screen w-full bg-brand-bg text-white flex flex-col items-center justify-between overflow-hidden pb-12">
    
    <div class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_center,rgba(15,118,110,0.15)_0%,rgba(2,44,34,1)_90%)]"></div>

    <Navbar />

    <div class="relative z-10 flex-1 flex flex-col items-center justify-center px-4 w-full select-none">
      
      <div class="main_wrapper">
        <div class="main">
          
          <div class="antenna">
            <div class="antenna_shadow"></div>
            <div class="a1"></div>
            <div class="a1d"></div>
            <div class="a2"></div>
            <div class="a2d"></div>
            <div class="a_base"></div>
          </div>
          
          <div class="tv">
            <div class="cruve">
              <svg
                class="curve_svg"
                version="1.1"
                xmlns="http://www.w3.org/2000/svg"
                xmlns:xlink="http://www.w3.org/1999/xlink"
                viewBox="0 0 189.929 189.929"
                xml:space="preserve"
              >
                <path
                  d="M70.343,70.343c-30.554,30.553-44.806,72.7-39.102,115.635l-29.738,3.951C-5.442,137.659,11.917,86.34,49.129,49.13
                  C86.34,11.918,137.664-5.445,189.928,1.502l-3.95,29.738C143.041,25.54,100.895,39.789,70.343,70.343z"
                ></path>
              </svg>
            </div>
            
            <div class="display_div">
              <div class="screen_out">
                <div class="screen_out1">
                  <div class="screen">
                    <span class="notfound_text">NOT FOUND</span>
                  </div>
                  <div class="screenM">
                    <span class="notfound_text">NOT FOUND</span>
                  </div>
                </div>
              </div>
            </div>
            
            <div class="lines">
              <div class="line1"></div>
              <div class="line2"></div>
              <div class="line3"></div>
            </div>
            
            <div class="buttons_div">
              <div class="b1"><div></div></div>
              <div class="b2"></div>
              <div class="speakers">
                <div class="g1">
                  <div class="g11"></div>
                  <div class="g12"></div>
                  <div class="g13"></div>
                </div>
                <div class="g"></div>
                <div class="g"></div>
              </div>
            </div>
          </div>
          
          <div class="bottom">
            <div class="base1"></div>
            <div class="base2"></div>
            <div class="base3"></div>
          </div>
          
        </div>

        <div class="text_404">
          <div class="text_4041">4</div>
          <div class="text_4042">0</div>
          <div class="text_4043">4</div>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a 
          href="/" 
          class="inline-flex items-center justify-center text-xs font-bold tracking-wider uppercase text-brand-text-dark bg-brand-accent hover:bg-emerald-300 active:scale-95 px-8 py-3.5 rounded-xl transition-all duration-150 shadow-lg shadow-brand-text-dark/40"
        >
          Return to Mission Control
        </a>
      </div>

    </div>

    <footer class="w-full text-center pt-8 text-[10px] tracking-widest text-emerald-500 uppercase">
      © {new Date().getFullYear()} Tolland County Robotics Foundation
    </footer>

  </div>
</Layout>

<style>
  /* Embedded Layout Calculations for the Retro CRT 404 Component */
  .main_wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30em;
    height: 30em;
    position: relative;
  }

  .main {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-top: 5em;
    position: relative;
  }

  .antenna {
    width: 5em;
    height: 5em;
    border-radius: 50%;
    border: 2px solid #022c22;
    background-color: #0f766e;
    margin-bottom: -6em;
    margin-left: 0em;
    z-index: 1;
    position: relative;
  }
  
  .antenna_shadow {
    position: absolute;
    background-color: transparent;
    width: 50px;
    height: 56px;
    margin-left: 1.68em;
    border-radius: 45%;
    transform: rotate(140deg);
    border: 4px solid transparent;
    box-shadow:
      inset 0px 16px #115e59,
      inset 0px 16px 1px 1px #115e59;
  }
  
  .antenna::after {
    content: "";
    position: absolute;
    margin-top: -9.4em;
    margin-left: 0.4em;
    transform: rotate(-25deg);
    width: 1em;
    height: 0.5em;
    border-radius: 50%;
    background-color: #14b8a6;
  }
  
  .antenna::before {
    content: "";
    position: absolute;
    margin-top: 0.2em;
    margin-left: 1.25em;
    transform: rotate(-20deg);
    width: 1.5em;
    height: 0.8em;
    border-radius: 50%;
    background-color: #14b8a6;
  }
  
  .a1 {
    position: relative;
    top: -102%;
    left: -130%;
    width: 12em;
    height: 5.5em;
    border-radius: 50px;
    background-image: linear-gradient(
      #022c22,
      #022c22,
      #115e59,
      #115e59,
      #022c22
    );
    transform: rotate(-29deg);
    clip-path: polygon(50% 0%, 49% 100%, 52% 100%);
  }
  
  .a1d {
    position: relative;
    top: -211%;
    left: -35%;
    transform: rotate(45deg);
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    border: 2px solid #022c22;
    background-color: #34d399;
    z-index: 99;
  }
  
  .a2 {
    position: relative;
    top: -210%;
    left: -10%;
    width: 12em;
    height: 4em;
    border-radius: 50px;
    background-image: linear-gradient(
      #022c22,
      #022c22,
      #115e59,
      #115e59,
      #022c22
    );
    margin-right: 5em;
    clip-path: polygon(
      47% 0,
      47% 0,
      34% 34%,
      54% 25.,
      32% 100%,
      29% 96%,
      49% 32%,
      30% 38%
    );
    transform: rotate(-8deg);
  }
  
  .a2d {
    position: relative;
    top: -294%;
    left: 94%;
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    border: 2px solid #022c22;
    background-color: #34d399;
    z-index: 99;
  }

  .notfound_text {
    background-color: #022c22;
    padding-left: 0.5em;
    padding-right: 0.5em;
    padding-top: 0.2em;
    padding-bottom: 0.2em;
    font-size: 0.75em;
    color: #34d399;
    font-weight: 900;
    letter-spacing: 0.05em;
    border-radius: 6px;
    border: 1px solid #115e59;
    z-index: 10;
  }
  
  .tv {
    width: 17em;
    height: 9em;
    margin-top: 3em;
    border-radius: 15px;
    background-color: #0f766e;
    display: flex;
    justify-content: center;
    border: 2px solid #022c22;
    box-shadow: inset 0.2em 0.2em #14b8a6;
    position: relative;
    z-index: 2;
  }
  
  .tv::after {
    content: "";
    position: absolute;
    width: 17em;
    height: 9em;
    border-radius: 15px;
    background:
      repeating-radial-gradient(#0f766e 0 0.0001%, #00000070 0 0.0002%) 50% 0/2500px 2500px,
      repeating-conic-gradient(#0f766e 0 0.0001%, #00000070 0 0.0002%) 60% 60%/2500px 2500px;
    background-blend-mode: difference;
    opacity: 0.09;
  }
  
  .curve_svg {
    position: absolute;
    margin-top: 0.25em;
    margin-left: -0.25em;
    height: 12px;
    width: 12px;
    fill: #022c22;
  }
  
  .display_div {
    display: flex;
    align-items: center;
    align-self: center;
    justify-content: center;
    border-radius: 15px;
    box-shadow: 3.5px 3.5px 0px #14b8a6;
  }
  
  .screen_out1 {
    width: 11em;
    height: 7.75em;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
  }
  
  .screen {
    width: 13em;
    height: 7.85em;
    font-family: inherit;
    border: 2px solid #022c22;
    background:
      repeating-radial-gradient(#000 0 0.0001%, #ffffff 0 0.0002%) 50% 0/2500px 2500px,
      repeating-conic-gradient(#000 0 0.0001%, #ffffff 0 0.0002%) 60% 60%/2500px 2500px;
    background-blend-mode: difference;
    animation: b 0.2s infinite alternate;
    border-radius: 10px;
    z-index: 99;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    color: #252525;
    letter-spacing: 0.15em;
    text-align: center;
  }

  .screenM {
    width: 13em;
    height: 7.85em;
    position: relative;
    font-family: inherit;
    background: linear-gradient(
      to right,
      #002fc6 0%, #002bb2 14.2857%,
      #3a3a3a 14.2857%, #303030 28.5714%,
      #ff0afe 28.5714%, #f500f4 42.8571%,
      #6c6c6c 42.8571%, #626262 57.1428%,
      #0affd9 57.1428%, #00f5ce 71.4286%,
      #3a3a3a 71.4286%, #303030 85.7142%,
      white 85.7142%, #fafafa 100%
    );
    border-radius: 10px;
    border: 2px solid #022c22;
    z-index: 99;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    color: #252525;
    letter-spacing: 0.15em;
    text-align: center;
    overflow: hidden;
  }
  
  .screenM:before,
  .screenM:after {
    content: "";
    position: absolute;
    left: 0;
    z-index: 1;
    width: 100%;
  }
  
  .screenM:before {
    top: 0;
    height: 68.4782%;
    background: linear-gradient(
      to right,
      white 0%, #fafafa 14.2857%,
      #ffe60a 14.2857%, #f5dc00 28.5714%,
      #0affd9 28.5714%, #00f5ce 42.8571%,
      #10ea00 42.8571%, #0ed600 57.1428%,
      #ff0afe 57.1428%, #f500f4 71.4286%,
      #ed0014 71.4286%, #d90012 85.7142%,
      #002fc6 85.7142%, #002bb2 100%
    );
  }
  
  .screenM:after {
    bottom: 0;
    height: 21.7391%;
    background: linear-gradient(
      to right,
      #006c6b 0%, #005857 16.6666%,
      white 16.6666%, #fafafa 33.3333%,
      #001b75 33.3333%, #001761 50%,
      #6c6c6c 50%, #626262 66.6666%,
      #929292 66.6666%, #888888 83.3333%,
      #3a3a3a 83.3333%, #303030 100%
    );
  }

  @keyframes b {
    100% {
      background-position: 50% 0, 60% 50%;
    }
  }

  .lines {
    display: flex;
    column-gap: 0.1em;
    align-self: flex-end;
  }
  
  .line1,
  .line3 {
    width: 2px;
    height: 0.5em;
    background-color: #022c22;
    border-radius: 25px 25px 0px 0px;
    margin-top: 0.5em;
  }
  
  .line2 {
    flex-grow: 1;
    width: 2px;
    height: 1em;
    background-color: #022c22;
    border-radius: 25px 25px 0px 0px;
  }

  .buttons_div {
    width: 4.25em;
    align-self: center;
    height: 8em;
    background-color: #115e59;
    border: 2px solid #022c22;
    padding: 0.6em;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    row-gap: 0.75em;
    box-shadow: 3px 3px 0px #14b8a6;
  }
  
  .b1 {
    width: 1.65em;
    height: 1.65em;
    border-radius: 50%;
    background-color: #022c22;
    border: 2px solid #115e59;
    box-shadow:
      inset 2px 2px 1px #0f766e,
      -2px 0px #022c22,
      -2px 0px 0px 1px #022c22;
  }
  
  .b1::before {
    content: "";
    position: absolute;
    margin-top: 1em;
    margin-left: 0.5em;
    transform: rotate(47deg);
    border-radius: 5px;
    width: 0.1em;
    height: 0.4em;
    background-color: #34d399;
  }
  
  .b1::after {
    content: "";
    position: absolute;
    margin-top: 0.9em;
    margin-left: 0.8em;
    transform: rotate(47deg);
    border-radius: 5px;
    width: 0.1em;
    height: 0.55em;
    background-color: #34d399;
  }
  
  .b1 div {
    content: "";
    position: absolute;
    margin-top: -0.1em;
    margin-left: 0.65em;
    transform: rotate(45deg);
    width: 0.15em;
    height: 1.5em;
    background-color: #34d399;
  }
  
  .b2 {
    width: 1.65em;
    height: 1.65em;
    border-radius: 50%;
    background-color: #022c22;
    border: 2px solid #115e59;
    box-shadow:
      inset 2px 2px 1px #0f766e,
      -2px 0px #022c22,
      -2px 0px 0px 1px #022c22;
  }
  
  .b2::before {
    content: "";
    position: absolute;
    margin-top: 1.05em;
    margin-left: 0.8em;
    transform: rotate(-45deg);
    border-radius: 5px;
    width: 0.15em;
    height: 0.4em;
    background-color: #34d399;
  }
  
  .b2::after {
    content: "";
    position: absolute;
    margin-top: -0.1em;
    margin-left: 0.65em;
    transform: rotate(-45deg);
    width: 0.15em;
    height: 1.5em;
    background-color: #34d399;
  }
  
  .speakers {
    display: flex;
    flex-direction: column;
    row-gap: 0.5em;
  }
  
  .speakers .g1 {
    display: flex;
    column-gap: 0.25em;
  }
  
  .speakers .g1 .g11,
  .g12,
  .g13 {
    width: 0.65em;
    height: 0.65em;
    border-radius: 50%;
    background-color: #022c22;
    border: 2px solid #115e59;
    box-shadow: inset 1.25px 1.25px 1px #0f766e;
  }
  
  .speakers .g {
    width: auto;
    height: 2px;
    background-color: #022c22;
  }

  .bottom {
    width: 100%;
    height: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    column-gap: 8.7em;
  }
  
  .base1 {
    height: 1em;
    width: 2em;
    border: 2px solid #022c22;
    background-color: #115e59;
    margin-top: -0.15em;
    z-index: 1;
  }
  
  .base2 {
    height: 1em;
    width: 2em;
    border: 2px solid #022c22;
    background-color: #115e59;
    margin-top: -0.15em;
    z-index: 1;
  }
  
  .base3 {
    position: absolute;
    height: 0.15em;
    width: 17.5em;
    background-color: #022c22;
    margin-top: 0.8em;
  }

  .text_404 {
    position: absolute;
    display: flex;
    flex-direction: row;
    column-gap: 6em;
    z-index: 0;
    margin-bottom: 2em;
    align-items: center;
    justify-content: center;
    opacity: 0.04; /* Muted contrast on green */
  }
  
  .text_4041,
  .text_4042,
  .text_4043 {
    transform: scaleY(24.5) scaleX(9);
    font-weight: 900;
    color: white;
  }

  @media only screen and (max-width: 495px) {
    .text_404 {
      column-gap: 6em;
    }
  }
  
  @media only screen and (max-width: 395px) {
    .text_404 {
      column-gap: 4em;
    }
    .text_4041,
    .text_4042,
    .text_4043 {
      transform: scaleY(25) scaleX(8);
    }
  }

  @media only screen and (max-width: 1024px) {
    .screenM {
      display: flex;
    }
    .screen {
      display: none;
    }
  }
  
  @media only screen and (min-width: 1025px) {
    .screen {
      display: flex;
    }
    .screenM {
      display: none;
    }
  }
</style>