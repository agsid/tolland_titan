---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import siteData from '../data/landing.json';
import '../styles/global.css';

const { hero, metrics, logistics } = siteData;
---

<Layout title="Tolland County Titans #23535">
  <div class="relative min-h-screen w-full bg-brand-bg text-white flex flex-col items-center overflow-x-hidden pb-12">
    
    <Navbar />

    <div class="relative z-10 w-full max-w-6xl px-4 mt-8 md:mt-16 flex flex-col gap-12">
      
      <main class="w-full bg-brand-card border border-emerald-800 rounded-3xl overflow-hidden grid lg:grid-cols-12 items-stretch shadow-xl">
        
        <div class="lg:col-span-7 p-8 sm:p-12 md:p-16 flex flex-col justify-center items-start text-left text-white">
          
          <div class="inline-flex items-center gap-2 bg-brand-bg/60 border border-emerald-900/50 rounded-full px-3 py-1 text-xs text-brand-accent mb-6 font-medium">
            <span>{hero.badgeText}</span>
            <span class="w-1.5 h-1.5 rounded-full bg-brand-accent"></span>
            <a href={hero.primaryCtaUrl} class="text-white hover:text-brand-accent transition-colors duration-150 font-semibold">
              {hero.badgeCta}
            </a>
          </div>

          <h1 class="text-3xl sm:text-4xl md:text-5xl font-black tracking-tight leading-tight mb-4 max-w-xl">
            {hero.headline}
          </h1>
          
          <p class="text-emerald-100/80 text-sm sm:text-base leading-relaxed mb-8 max-w-lg">
            {hero.subheading}
          </p>

          <div class="flex flex-wrap items-center gap-4">
            <a 
              href={hero.primaryCtaUrl} 
              class="inline-flex items-center justify-center text-xs font-bold tracking-wider uppercase text-brand-text-dark bg-white hover:bg-slate-100 active:scale-95 px-6 py-3.5 rounded-xl transition-all duration-150 shadow"
            >
              {hero.primaryCtaText}
            </a>
            <a 
              href={hero.secondaryCtaUrl} 
              class="inline-flex items-center justify-center text-xs font-bold tracking-wider uppercase text-white bg-brand-bg/40 border border-emerald-800/60 hover:bg-brand-bg/80 active:scale-95 px-6 py-3.5 rounded-xl transition-all duration-150"
            >
              {hero.secondaryCtaText}
            </a>
          </div>

        </div>

        <div class="lg:col-span-5 relative min-h-[300px] lg:min-h-full bg-brand-bg/40 border-t lg:border-t-0 lg:border-l border-emerald-900/40">
          <img 
            src="/images/robot.png" 
            alt="FTC Team 23535 Robot Framework" 
            loading="lazy"
            decoding="async"
            class="absolute inset-0 w-full h-full object-cover object-center select-none pointer-events-none mix-blend-luminosity opacity-80"
          />
        </div>

      </main>

      <section class="grid grid-cols-2 md:grid-cols-4 gap-6 px-4 w-full max-w-4xl mx-auto">
        {metrics.map((metric) => (
          <div class="flex flex-col items-start border-l-2 border-brand-accent pl-4">
            <span class="text-2xl font-extrabold tracking-tight text-white font-mono">
              {metric.value}
            </span>
            <span class="text-[10px] font-bold tracking-wider text-emerald-300 uppercase mt-0.5">
              {metric.label}
            </span>
          </div>
        ))}
      </section>

    </div>

    <div id="join-us" class="w-full mt-16 md:mt-24 border-t border-emerald-900 bg-brand-bg/20 scroll-mt-20">
      <section class="w-full max-w-6xl mx-auto px-4 py-16 grid lg:grid-cols-12 gap-8 items-start">
        
        <div class="lg:col-span-5 flex flex-col gap-6 text-left">
          <div>
            <span class="text-xs font-bold tracking-widest text-brand-accent uppercase">Information</span>
            <h2 class="text-2xl font-black text-white tracking-tight mt-1 mb-4">Team Overview</h2>
            <p class="text-emerald-100/70 text-xs sm:text-sm leading-relaxed">
              {logistics.aboutText}
            </p>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div class="bg-brand-card border border-emerald-800 p-5 rounded-xl shadow-sm">
              <span class="text-[10px] uppercase tracking-wider font-bold text-emerald-300">Lab Location</span>
              <p class="text-xs font-bold text-white mt-1">{logistics.address}</p>
            </div>

            <div class="bg-brand-card border border-emerald-800 p-5 rounded-xl flex flex-col justify-between shadow-sm">
              <div>
                <span class="text-[10px] uppercase tracking-wider font-bold text-emerald-300">Eligibility</span>
                <p class="text-xs font-bold text-white mt-1">{logistics.grades}</p>
              </div>
              <div class="mt-2 pt-2 border-t border-emerald-800/40">
                <span class="text-xs font-bold text-brand-accent">Cost: {logistics.cost}</span>
              </div>
            </div>
          </div>
        </div>

        <div class="lg:col-span-7 w-full">
          <div class="bg-brand-card border border-emerald-800 p-6 sm:p-8 rounded-xl shadow-sm">
            <div class="flex flex-wrap justify-between items-center gap-2 mb-4">
              <span class="text-[10px] uppercase tracking-wider font-bold text-emerald-300">Practice Lab Hours</span>
              <span class="text-[10px] text-brand-accent font-bold px-2.5 py-0.5 rounded-full bg-brand-bg border border-emerald-800">
                {logistics.seasonNote}
              </span>
            </div>
            
            <div class="space-y-2.5">
              {logistics.schedule.map((slot) => (
                <div class="flex justify-between items-center text-xs border-b border-emerald-800/40 pb-2.5 last:border-none last:pb-0">
                  <span class="font-bold text-slate-200">{slot.days}</span>
                  <span class="font-mono text-emerald-100 bg-brand-bg border border-emerald-800 px-2.5 py-1 rounded">
                    {slot.time}
                  </span>
                </div>
              ))}
            </div>
          </div>
        </div>

      </section>
    </div>

    <footer class="w-full text-center mt-auto pt-12 pb-4 text-[10px] tracking-widest text-emerald-400 uppercase">
      © {new Date().getFullYear()} Tolland County Robotics Foundation
    </footer>

  </div>
</Layout>